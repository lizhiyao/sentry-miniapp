{
  "name": "sentry-miniapp",
  "version": "1.3.1",
  "description": "用于小程序平台的 Sentry SDK",
  "repository": {
    "type": "git",
    "url": "git://github.com/lizhiyao/sentry-miniapp.git"
  },
  "homepage": "https://github.com/lizhiyao/sentry-miniapp",
  "scripts": {
    "build": "vite build && npm run sync:examples",
    "sync:examples": "cp dist/sentry-miniapp.umd.js examples/wxapp/lib/sentry-miniapp.js",
    "build:miniapp": "vite build --mode miniapp",
    "build:types": "vite build && tsc --emitDeclarationOnly --outDir dist/types",
    "dev": "vite build --watch",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:integration": "npm run build && cp dist/sentry-miniapp.umd.js examples/wxapp/lib/sentry-miniapp.js && node integration-tests/test-duplicate-async-error.js && node integration-tests/test-multiple-exceptions.js && node integration-tests/test-size-limit-fix.js",
    "test:all": "npm run test && npm run test:integration",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "sentry",
    "miniapp",
    "wechat",
    "alipay",
    "bytedance",
    "swan",
    "kuaishou",
    "dingtalk",
    "qq",
    "taro",
    "uniapp",
    "error-monitoring",
    "exception-tracking",
    "performance-monitoring",
    "sourcemap",
    "offline-cache",
    "小程序",
    "微信小程序",
    "支付宝小程序",
    "字节跳动小程序",
    "抖音小程序",
    "百度小程序",
    "快手小程序",
    "钉钉小程序",
    "QQ小程序",
    "跨端开发",
    "异常监控",
    "错误收集",
    "性能监控",
    "前端监控"
  ],
  "author": "dancerlzy@gmail.com",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "main": "dist/sentry-miniapp.cjs.js",
  "module": "dist/sentry-miniapp.esm.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/sentry-miniapp.esm.js",
      "require": "./dist/sentry-miniapp.cjs.js"
    }
  },
  "files": [
    "dist",
    "lib"
  ],
  "devDependencies": {
    "@jest/globals": "^30.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.11",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vue/language-core": "^3.2.6",
    "eslint": "^8.0.0",
    "husky": "^9.1.7",
    "jest": "^29.0.0",
    "js-yaml": "3.14.2",
    "lint-staged": "^16.4.0",
    "lodash": "4.17.23",
    "rollup-plugin-visualizer": "^7.0.1",
    "ts-jest": "^29.4.0",
    "typescript": "^5.8.3",
    "vite": "^6.4.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "@sentry/core": "^10.45.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix"
    ]
  }
}